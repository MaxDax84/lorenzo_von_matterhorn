{
  "manifest_version": 3,
  "name": "Foogle — Ricerca Famosa",
  "version": "1.0",
  "description": "Intercetta le ricerche Google dei tuoi amici famosi e mostra i loro veri risultati.",

  "permissions": ["storage"],
  "host_permissions": [
    "*://www.google.com/*",
    "*://google.com/*",
    "*://www.google.it/*",
    "*://google.it/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/search*",
        "*://google.com/search*",
        "*://www.google.it/search*",
        "*://google.it/search*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Foogle",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
